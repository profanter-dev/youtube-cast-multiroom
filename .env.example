# Where persistent data lives on the host (snapfifo + musicbridge auth).
DATA_DIR=/opt/youtube-cast-multiroom

# Hostnames routed by Traefik.
MUSIC_HOST=music.example.com
SNAPCAST_HOST=snapcast.example.com

# Basic-auth credentials for the music web UI, as an htpasswd user:hash pair.
# Generate with:  htpasswd -nbB youruser yourpassword
# IMPORTANT: in this .env file, every literal "$" must be doubled to "$$".
MUSIC_AUTH=youruser:$$2y$$05$$replace.with.your.bcrypt.hash

# Google OAuth client for "Sign in with Google" (Library/Playlists). Create a
# "TVs and Limited Input devices" OAuth client in Google Cloud Console (see
# README). Leave blank to skip — public search still works without it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
